/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://*.supabase.co https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://images.unsplash.com https://*.supabase.co https://www.google-analytics.com https://cdn.portalturismoportugal.com data:; connect-src 'self' https://*.supabase.co https://marine-api.open-meteo.com https://api.open-meteo.com https://www.google-analytics.com https://region1.google-analytics.com https://stats.g.doubleclick.net https://www.googletagmanager.com https://challenges.cloudflare.com; media-src 'self' https://cdn.portalturismoportugal.com; frame-src https://portalturismoportugal.lemonsqueezy.com https://challenges.cloudflare.com

# Static brand assets — long cache (immutable per filename)
/favicon.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Content-Type: image/vnd.microsoft.icon
  Cache-Control: public, max-age=31536000, immutable

/apple-touch-icon.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/icon-192.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/icon-512.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/icon-maskable-192.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/icon-maskable-512.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/favicon-16.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/favicon-32.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/og-image.png
  Content-Type: image/png
  Cache-Control: public, max-age=86400

/og-image.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=86400

/manifest.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=3600
